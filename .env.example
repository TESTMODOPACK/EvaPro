# ══════════════════════════════════════════════════════════════════════
# Eva360 — Variables de entorno para producción (Hostinger VPS)
# ══════════════════════════════════════════════════════════════════════
# Copiar este archivo como .env y completar los valores:
#   cp .env.example .env
#   nano .env
# ══════════════════════════════════════════════════════════════════════

# ── Base de Datos PostgreSQL ─────────────────────────────────────────
DB_NAME=eva360
DB_USER=eva360
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ── Base de Datos — Connection Pool ──────────────────────────────────
# Max conexiones simultaneas del API al Postgres. Default: 20 en prod.
# Render starter tiene max_connections=100 — dejar margen para seeds,
# migrations, monitoreo, etc.
DB_POOL_MAX=20
# Min conexiones idle (calientes). Default: 2.
DB_POOL_MIN=2

# ── Seguridad ────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIAR_POR_SECRETO_JWT_SEGURO

# ── URLs de la aplicación ────────────────────────────────────────────
# URL pública donde se accede a la app (sin trailing slash)
APP_URL=https://eva360.tudominio.cl
# URL del API (con /api si usas nginx reverse proxy)
API_URL=https://eva360.tudominio.cl/api

# ── Email (Resend) ───────────────────────────────────────────────────
# Obtener en https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXX
# Remitente por defecto (el dominio debe estar verificado en Resend)
EMAIL_FROM=Eva360 <notificaciones@tudominio.cl>

# ── Inteligencia Artificial (Anthropic Claude) ───────────────────────
# Obtener en https://console.anthropic.com/settings/keys
# Dejar vacío si no se usa IA (las funciones de IA quedan desactivadas)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXX

# ── Observabilidad (Sentry + pino) ───────────────────────────────────
# Sentry — captura errores, performance tracing y profiling en prod.
# Si SENTRY_DSN queda vacío, Sentry queda completamente desactivado
# (es seguro para dev local, no requiere cuenta).
#
# Crear proyecto en https://sentry.io → Platform: NestJS → Copiar DSN
SENTRY_DSN=
# Entorno que aparece en el dashboard de Sentry (production/staging/development).
# Default: el valor de NODE_ENV.
SENTRY_ENVIRONMENT=production
# Version/release para tracking de regresiones. Render/Netlify setean el
# SHA del commit automaticamente via RENDER_GIT_COMMIT. En Docker hay
# que setearlo manualmente si lo querés, o dejarlo vacío.
SENTRY_RELEASE=
# Sampling — 0.1 = 10% de requests con performance tracing (suficiente
# para p95/p99). Subir a 1.0 en dev para ver todo.
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Pino — controla verbosidad del logger estructurado.
# Valores: trace / debug / info / warn / error / fatal
LOG_LEVEL=info

# ── Metricas Prometheus ──────────────────────────────────────────────
# Protege el endpoint /metrics con basic auth (metadata sensible).
# Si no estan definidos, /metrics queda abierto (solo para dev local).
METRICS_USER=prometheus
METRICS_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ── Datos legales del Proveedor (Ascenda) ───────────────────────────
# Se usan para rellenar los placeholders de TODOS los contratos legales
# generados para los clientes (prestación de servicios, DPA, T&C, privacy,
# SLA, NDA). Si no se setean, se usan los defaults hardcoded en el config
# (backwards-compatible). Editar + reiniciar api container cuando cambie
# CEO / razón social / domicilio. Los contratos ya firmados son
# inmutables — solo aplica a bulk-create posteriores.
ASCENDA_COMPANY_NAME=ASCENDA PERFORMANCE SpA
ASCENDA_COMPANY_RUT=78.396.131-8
ASCENDA_COMPANY_ADDRESS=Fresia 2020, La Pintana, Santiago
ASCENDA_LEGAL_REP_NAME=Ricardo Morales Olate
ASCENDA_LEGAL_REP_RUT=12.121.896-8
ASCENDA_SUPPORT_EMAIL=soporte@ascenda.cl
# Teléfono de soporte (opcional, default vacío)
ASCENDA_SUPPORT_PHONE=

# ── Sentry Frontend (Next.js) ────────────────────────────────────────
# Mismo proyecto Sentry del backend, o uno separado (recomendado separado
# para ver errores frontend vs backend en dashboards distintos).
# NEXT_PUBLIC_ prefix hace que la variable esté disponible en el browser.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# Source maps del frontend (P1.4) — para que los stack traces en Sentry
# salgan legibles en vez de minificados. Sin estos, bugs en prod son
# intratables. Crear token en:
#   sentry.io → Settings → Auth Tokens → scope: project:releases + project:write
# El docker-compose pasa estas vars como build args al Dockerfile de web.
# Requieren rebuild del container web cuando cambien (`docker compose
# build --no-cache web`).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
