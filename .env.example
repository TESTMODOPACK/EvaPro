# ══════════════════════════════════════════════════════════════════════
# Eva360 — Variables de entorno para producción (Hostinger VPS)
# ══════════════════════════════════════════════════════════════════════
# Copiar este archivo como .env y completar los valores:
#   cp .env.example .env
#   nano .env
# ══════════════════════════════════════════════════════════════════════

# ── Base de Datos PostgreSQL ─────────────────────────────────────────
# `DB_USER` es el rol admin/superuser (lo crea el bootstrap del image
# postgres:16-alpine). Lo usan: pg_dump/pg_restore, migrations,
# scripts admin. NO lo usa la app del API en runtime (ver abajo).
DB_NAME=eva360
DB_USER=eva360
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ── App role (F4 RLS Role Separation) ────────────────────────────────
# F4 RLS requiere que la app conecte como un rol NON-superuser para que
# las policies RLS apliquen realmente (SUPERUSER tiene BYPASSRLS).
#
# Opcion 1 — DEJAR VACIO mientras no se aplica role separation:
#   El docker-compose hace fallback a DB_USER/DB_PASSWORD (eva360
#   superuser). Funciona pero RLS Fase B/C son decorativas.
#
# Opcion 2 — TENER role separation aplicado:
#   1. Generar password fuerte distinto al admin:
#      openssl rand -base64 32 | tr -d '/+=' | head -c 32
#   2. Aplicar SQL:
#      apps/api/src/database/sql/2026-04-28-create-eva360-app-role.sql
#      pasando ese password via -v eva360_app_password='...'
#   3. Setear ambas variables abajo con el rol y password creados.
#   4. docker compose up -d --force-recreate api
#   5. Aplicar SQL de RLS Fase B/C — ya protegen efectivamente.
DB_APP_USER=
DB_APP_PASSWORD=

# ── Base de Datos — Connection Pool ──────────────────────────────────
# Max conexiones simultaneas del API al Postgres. Default: 20 en prod.
# Render starter tiene max_connections=100 — dejar margen para seeds,
# migrations, monitoreo, etc.
DB_POOL_MAX=20
# Min conexiones idle (calientes). Default: 2.
DB_POOL_MIN=2

# ── Seguridad ────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIAR_POR_SECRETO_JWT_SEGURO

# Firma las state cookies del flujo OIDC (SSO). DEBE ser distinto de
# JWT_SECRET — el punto de tener dos es defensa-en-profundidad: si uno
# se compromete, el otro sigue protegiendo su superficie.
# En prod main.ts hace fail-fast si falta o es igual a JWT_SECRET.
# En dev opcional (sso.service.ts cae al JWT_SECRET como fallback).
# Generar con: openssl rand -hex 32
SSO_STATE_SECRET=CAMBIAR_POR_SECRETO_SSO_SEGURO

# ── URLs de la aplicación ────────────────────────────────────────────
# URL pública donde se accede a la app (sin trailing slash)
APP_URL=https://eva360.tudominio.cl
# URL del API (con /api si usas nginx reverse proxy)
API_URL=https://eva360.tudominio.cl/api

# ── Email (Resend) ───────────────────────────────────────────────────
# Obtener en https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXX
# Remitente por defecto (el dominio debe estar verificado en Resend)
EMAIL_FROM=Eva360 <notificaciones@tudominio.cl>

# ── Inteligencia Artificial (Anthropic Claude) ───────────────────────
# Obtener en https://console.anthropic.com/settings/keys
# Dejar vacío si no se usa IA (las funciones de IA quedan desactivadas)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXX

# ── Observabilidad (Sentry + pino) ───────────────────────────────────
# Sentry — captura errores, performance tracing y profiling en prod.
# Si SENTRY_DSN queda vacío, Sentry queda completamente desactivado
# (es seguro para dev local, no requiere cuenta).
#
# Crear proyecto en https://sentry.io → Platform: NestJS → Copiar DSN
SENTRY_DSN=
# Entorno que aparece en el dashboard de Sentry (production/staging/development).
# Default: el valor de NODE_ENV.
SENTRY_ENVIRONMENT=production
# Version/release para tracking de regresiones. Render/Netlify setean el
# SHA del commit automaticamente via RENDER_GIT_COMMIT. En Docker hay
# que setearlo manualmente si lo querés, o dejarlo vacío.
SENTRY_RELEASE=
# Sampling — 0.1 = 10% de requests con performance tracing (suficiente
# para p95/p99). Subir a 1.0 en dev para ver todo.
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Pino — controla verbosidad del logger estructurado.
# Valores: trace / debug / info / warn / error / fatal
LOG_LEVEL=info

# ── Audit log retention (P2.2) ───────────────────────────────────────
# Cron diario (04:30 AM) purga audit_logs viejos conforme GDPR.
# Regular: operaciones cotidianas. Crítico: pagos/firmas/GDPR/role changes
# que exige SII Chile o evidencia contractual — se preservan más tiempo.
AUDIT_LOGS_RETENTION_YEARS=2
AUDIT_LOGS_CRITICAL_RETENTION_YEARS=6

# ── Metricas Prometheus ──────────────────────────────────────────────
# Protege el endpoint /metrics con basic auth (metadata sensible).
# Si no estan definidos, /metrics queda abierto (solo para dev local).
METRICS_USER=prometheus
METRICS_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ── Lead capture (P4) ────────────────────────────────────────────────
# POST /public/leads — form de contacto de ascenda.cl + eva360.ascenda.cl
#
# Cloudflare Turnstile (CAPTCHA server-side).
#   1. Crear sitio en https://dash.cloudflare.com/?to=/:account/turnstile
#   2. Seleccionar "Managed" mode (invisible para la mayoria de usuarios)
#   3. Copiar el Secret Key aqui; el Site Key va en el HTML de la landing
#
# Si queda vacio, el CAPTCHA se acepta sin verificar (dev friendly) y el
# backend registra captcha_verdict='bypassed_dev' en la entity Lead.
# En prod SIEMPRE debe estar configurado.
TURNSTILE_SECRET_KEY=

# Email destino de la notificacion interna cuando llega un nuevo lead.
# Default: contacto@ascenda.cl. Cambiar si se quiere redirigir a otra
# bandeja (ej. Slack-via-email, webhook de Zapier, o un grupo comercial).
LEADS_NOTIFY_TO=contacto@ascenda.cl

# ── Health monitor (self-alerting) ───────────────────────────────────
# Cron cada 5 min hace ping a la DB. Si falla 2 veces consecutivas,
# manda alerta por email (y otra cuando se restablezca). Cooldown 30 min.
# Si se deja vacio, usa LEADS_NOTIFY_TO → contacto@ascenda.cl como fallback.
HEALTH_ALERT_TO=

# IMPORTANTE: para que el form de ascenda.cl pueda hacer POST al API,
# agregar el dominio a FRONTEND_URL (separados por coma):
#   FRONTEND_URL=https://eva360.ascenda.cl,https://ascenda.cl,https://www.ascenda.cl
# Si no, el browser bloqueara el fetch con CORS error.

# ── Datos legales del Proveedor (Ascenda) ───────────────────────────
# Se usan para rellenar los placeholders de TODOS los contratos legales
# generados para los clientes (prestación de servicios, DPA, T&C, privacy,
# SLA, NDA). Si no se setean, se usan los defaults hardcoded en el config
# (backwards-compatible). Editar + reiniciar api container cuando cambie
# CEO / razón social / domicilio. Los contratos ya firmados son
# inmutables — solo aplica a bulk-create posteriores.
ASCENDA_COMPANY_NAME=ASCENDA PERFORMANCE SpA
ASCENDA_COMPANY_RUT=78.396.131-8
ASCENDA_COMPANY_ADDRESS=Fresia 2020, La Pintana, Santiago
ASCENDA_LEGAL_REP_NAME=Ricardo Morales Olate
ASCENDA_LEGAL_REP_RUT=12.121.896-8
ASCENDA_SUPPORT_EMAIL=soporte@ascenda.cl
# Teléfono de soporte (opcional, default vacío)
ASCENDA_SUPPORT_PHONE=

# ── Web Push Notifications (VAPID) ───────────────────────────────────
# Claves para Web Push Protocol (notificaciones PWA al navegador).
# Generar con:
#   docker compose exec api npx web-push generate-vapid-keys
#   (o localmente: npx web-push generate-vapid-keys)
#
# Si cualquiera queda vacia, PushService arranca deshabilitado: emite
# warn al boot, /push/public-key devuelve 404, y el frontend trata push
# como "no soportado". La app funciona sin esto — solo se pierden las
# notificaciones push al navegador.
#
# VAPID_SUBJECT debe ser "mailto:<email>" (requerido por el spec Web
# Push — el push service usa ese contacto en caso de reportes de abuso).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@tudominio.cl

# ── Sentry Frontend (Next.js) ────────────────────────────────────────
# Mismo proyecto Sentry del backend, o uno separado (recomendado separado
# para ver errores frontend vs backend en dashboards distintos).
# NEXT_PUBLIC_ prefix hace que la variable esté disponible en el browser.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# Source maps del frontend (P1.4) — para que los stack traces en Sentry
# salgan legibles en vez de minificados. Sin estos, bugs en prod son
# intratables. Crear token en:
#   sentry.io → Settings → Auth Tokens → scope: project:releases + project:write
# El docker-compose pasa estas vars como build args al Dockerfile de web.
# Requieren rebuild del container web cuando cambien (`docker compose
# build --no-cache web`).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
