{
    "name": "@repo/api",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/database/cleanup-orphans.js && node dist/database/add-push-tables.js && node dist/main",
        "db:DANGER:reset-schema": "echo '⚠️  ESTO BORRA TODAS LAS TABLAS Y RECREA EL SCHEMA. Solo para entornos de desarrollo.' && ts-node -r tsconfig-paths/register src/database/schema-sync.ts",
        "db:migrate:push": "ts-node -r tsconfig-paths/register src/database/add-push-tables.ts",
        "db:seed": "ts-node -r tsconfig-paths/register src/database/seed.ts",
        "db:seed-full": "ts-node -r tsconfig-paths/register src/database/seed-demo-full.ts",
        "db:seed:demo": "node dist/database/seed.js && node dist/database/seed-demo-full.js",
        "migration:generate": "npx typeorm-ts-node-commonjs migration:generate -d src/database/datasource.ts",
        "migration:run": "npx typeorm-ts-node-commonjs migration:run -d src/database/datasource.ts",
        "migration:revert": "npx typeorm-ts-node-commonjs migration:revert -d src/database/datasource.ts",
        "migration:show": "npx typeorm-ts-node-commonjs migration:show -d src/database/datasource.ts",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:ci": "jest --ci --coverage --forceExit --maxWorkers=50%",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.80.0",
        "@nestjs/cache-manager": "^3.0.1",
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.0.1",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/typeorm": "^11.0.0",
        "@sentry/nestjs": "^10.21.0",
        "@sentry/profiling-node": "^10.21.0",
        "@types/archiver": "^7.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/multer": "^2.1.0",
        "@willsoto/nestjs-prometheus": "^6.0.1",
        "archiver": "^7.0.1",
        "bcrypt": "^6.0.0",
        "cache-manager": "^6.4.2",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "cloudinary": "^2.9.0",
        "cookie-parser": "^1.4.7",
        "exceljs": "^4.4.0",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.7",
        "mammoth": "^1.12.0",
        "mercadopago": "^2.12.0",
        "multer": "^2.1.1",
        "nestjs-pino": "^4.5.0",
        "nodemailer": "^8.0.3",
        "openid-client": "5",
        "passport-jwt": "^4.0.1",
        "pdf-parse": "1.1.1",
        "pg": "^8.20.0",
        "pino": "^9.5.0",
        "pino-http": "^10.3.0",
        "pino-pretty": "^11.3.0",
        "pptxgenjs": "^4.0.1",
        "prom-client": "^15.1.3",
        "reflect-metadata": "^0.2.2",
        "resend": "^6.9.4",
        "rxjs": "^7.8.1",
        "stripe": "^22.0.2",
        "typeorm": "^0.3.28",
        "typeorm-transactional": "^0.5.0",
        "web-push": "^3.6.7"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.10.7",
        "@types/nodemailer": "^7.0.11",
        "@types/passport-jwt": "^4.0.1",
        "@types/pg": "^8.11.11",
        "@types/supertest": "^6.0.2",
        "@types/web-push": "^3.6.4",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "globals": "^16.0.0",
        "jest": "^30.0.0",
        "prettier": "^3.4.2",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "modules/**/*.service.ts",
            "modules/**/*.controller.ts",
            "common/**/*.ts",
            "!**/*.module.ts",
            "!**/*.entity.ts",
            "!**/*.dto.ts",
            "!**/index.ts",
            "!database/**"
        ],
        "coverageDirectory": "../coverage",
        "coverageReporters": [
            "text",
            "text-summary",
            "lcov"
        ],
        "coverageThreshold": {
            "global": {
                "branches": 1,
                "functions": 1,
                "lines": 2,
                "statements": 2
            }
        },
        "testEnvironment": "node",
        "testTimeout": 30000,
        "maxWorkers": "50%"
    }
}
